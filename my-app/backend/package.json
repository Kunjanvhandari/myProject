{
  "name": "librivista-backend",
  "version": "1.0.0",
  "description": "Backend API for Librivista library management system",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "seed:worldlibrary": "node seed-worldlibrary.js",
    "seed:cdc": "node seed-all-cdc-textbooks.js",
    "seed:all": "node seed-worldlibrary.js && node seed-all-cdc-textbooks.js",
    "download:cdc": "node download-cdc-pdfs.js",
    "extract:chapters": "node extract-pdf-chapters.js"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1",
    "multer": "^2.1.1",
    "pdfjs-dist": "^5.7.284"
  }
}
